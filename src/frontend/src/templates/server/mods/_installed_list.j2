{% if installed_mods %}
<table class="table installed-mods-table">
    <thead>
        <tr>
            <th scope="col">Mod</th>
            <th scope="col">Version</th>
        </tr>
    </thead>
    <tbody>
        {% for mod in installed_mods %}
        <tr>
            <td>
                <strong>{{ mod.name }}</strong>
            </td>
            <td>{{ mod.version or '—' }}</td>
        </tr>
        {% endfor %}
    </tbody>
</table>
{% else %}
<p class="mb0">No mods installed for this server.</p>
{% endif %}
